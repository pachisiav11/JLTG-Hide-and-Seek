# Local secrets — never commit the real Maps API key.
config.js

# Firebase secrets (Phase 43, native push). The service-account key lives ONLY in
# the FIREBASE_SERVICE_ACCOUNT env var on Render — never in the repo. google-services.json
# sits under the git-ignored android/ already, but pin it here too so a stray copy
# anywhere in the tree can't be committed.
google-services.json
**/google-services.json
firebase-service-account*.json
serviceAccount*.json

# Node / tooling
node_modules/
npm-debug.log*
*.log

# OS / editor cruft
.DS_Store
Thumbs.db
.vscode/
.idea/

# Local dev/preview tooling
.claude/

# Capacitor / Android native build (Phase 39). The android/ project is generated
# by `npx cap add android` and rebuilt from capacitor.config.ts + capacitor-www/;
# it (and its Gradle/keystore output) is not committed. Never commit a keystore.
/android/
*.keystore
*.jks
